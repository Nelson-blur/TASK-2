@{
    ViewData["Title"] = "Contact Us";
}
<div class="glh-page-header"><div><h1>Contact Us</h1><p>We're here to help with any questions or queries.</p></div></div>
<div class="row g-4">
    <div class="col-lg-7">
        <div class="glh-card p-4">
            <h2 style="font-size:1.1rem;font-weight:800;color:var(--green-dark);margin-bottom:1.25rem;">Send us a message</h2>
            <form aria-label="Contact form">
                <div class="row g-3">
                    <div class="col-sm-6"><label for="firstName" class="glh-label">First name</label><input type="text" id="firstName" class="form-control" placeholder="First name" aria-required="true" /></div>
                    <div class="col-sm-6"><label for="lastName" class="glh-label">Last name</label><input type="text" id="lastName" class="form-control" placeholder="Last name" aria-required="true" /></div>
                    <div class="col-12"><label for="email" class="glh-label">Email address</label><input type="email" id="email" class="form-control" placeholder="your@email.com" aria-required="true" /></div>
                    <div class="col-12">
                        <label for="subject" class="glh-label">Subject</label>
                        <select id="subject" class="form-select" aria-label="Select subject">
                            <option value="">General enquiry</option>
                            <option>Order query</option>
                            <option>Product question</option>
                            <option>Become a producer</option>
                            <option>Accessibility support</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="col-12"><label for="message" class="glh-label">Message</label><textarea id="message" class="form-control" rows="5" placeholder="How can we help?" aria-required="true" maxlength="1000"></textarea></div>
                    <div class="col-12"><button type="submit" class="btn btn-primary w-100 py-2">Send Message</button></div>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-5 d-flex flex-column gap-3">
        <div class="glh-card p-3 d-flex gap-3 align-items-start">
            <div style="width:38px;height:38px;background:#EAF3DE;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;" aria-hidden="true">📍</div>
            <div><p style="font-size:11px;font-weight:800;color:var(--green-dark);margin:0 0 2px;text-transform:uppercase;">Address</p><p style="font-size:13px;color:var(--text-muted);margin:0;line-height:1.6;">Market Lane, Greenfield GF1 2AB</p></div>
        </div>
        <div class="glh-card p-3 d-flex gap-3 align-items-start">
            <div style="width:38px;height:38px;background:#EAF3DE;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;" aria-hidden="true">📞</div>
            <div><p style="font-size:11px;font-weight:800;color:var(--green-dark);margin:0 0 2px;text-transform:uppercase;">Phone</p><a href="tel:01234567890" style="font-size:13px;color:var(--text-muted);">01234 567890</a></div>
        </div>
        <div class="glh-card p-3 d-flex gap-3 align-items-start">
            <div style="width:38px;height:38px;background:#EAF3DE;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;" aria-hidden="true">✉️</div>
            <div><p style="font-size:11px;font-weight:800;color:var(--green-dark);margin:0 0 2px;text-transform:uppercase;">Email</p><a href="mailto:hello@greenfieldlocalhub.co.uk" style="font-size:13px;color:var(--text-muted);">hello@greenfieldlocalhub.co.uk</a></div>
        </div>
        <div class="glh-card p-3 d-flex gap-3 align-items-start">
            <div style="width:38px;height:38px;background:#EAF3DE;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;" aria-hidden="true">🕐</div>
            <div><p style="font-size:11px;font-weight:800;color:var(--green-dark);margin:0 0 2px;text-transform:uppercase;">Opening Hours</p><p style="font-size:13px;color:var(--text-muted);margin:0;line-height:1.6;">Mon–Sat 09:00–18:00<br />Sun 10:00–16:00</p></div>
        </div>
        <div class="glh-card p-3" style="border-left:4px solid var(--green-mid);">
            <p style="font-size:11.5px;font-weight:800;color:var(--green-dark);margin:0 0 4px;">♿ Accessibility Support</p>
            <p style="font-size:12.5px;color:var(--text-muted);margin:0;line-height:1.6;">We offer large-print order sheets, phone ordering and in-store assistance. Contact us to arrange support.</p>
        </div>
    </div>
</div>

