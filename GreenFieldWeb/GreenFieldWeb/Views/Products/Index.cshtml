@model IEnumerable<GreenFieldWeb.Models.Products>
@{
    ViewData["Title"] = "Products";
}

<h1>Products</h1>

@if (User.IsInRole("Producer") || User.IsInRole("Admin"))
{
    <p><a asp-action="Create" class="btn btn-success">+ Add New Product</a></p>
}

<table class="table">
    <thead>
        <tr>
            <th>Image</th>
            <th>@Html.DisplayNameFor(m => m.ProductName)</th>
            <th>@Html.DisplayNameFor(m => m.Price)</th>
            <th>@Html.DisplayNameFor(m => m.Stock)</th>
            <th>@Html.DisplayNameFor(m => m.Description)</th>
            <th>@Html.DisplayNameFor(m => m.AllergenInformation)</th>
            <th>@Html.DisplayNameFor(m => m.FarmingMethod)</th>
            <th>Producer</th>
            <th>@Html.DisplayNameFor(m => m.IsAvailable)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="~/images/@item.ImageUrl" alt="@item.ProductName"
                             style="width:60px; height:60px; object-fit:cover; border-radius:8px;" />
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.ProductName)</td>
                <td>£@item.Price.ToString("0.00")</td>
                <td>@Html.DisplayFor(modelItem => item.Stock)</td>
                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                <td>@Html.DisplayFor(modelItem => item.AllergenInformation)</td>
                <td>@Html.DisplayFor(modelItem => item.FarmingMethod)</td>
                <td>@Html.DisplayFor(modelItem => item.Producers.ProducerName)</td>
                <td>@Html.DisplayFor(modelItem => item.IsAvailable)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.ProductsId">Details</a>

                    @if (User.IsInRole("Producer") || User.IsInRole("Admin"))
                    {
                        <span> | </span>
                        <a asp-action="Edit" asp-route-id="@item.ProductsId">Edit</a>
                        <span> | </span>
                        <a asp-action="Delete" asp-route-id="@item.ProductsId">Delete</a>
                    }

                    @if (User.Identity.IsAuthenticated && !User.IsInRole("Producer") && !User.IsInRole("Admin"))
                    {
                        <form asp-controller="BasketProducts" asp-action="Create" method="post">
                            <input type="hidden" name="ProductsId" value="@item.ProductsId" />
                            @Html.AntiForgeryToken()
                            @if (item.Stock > 0)
                            {
                                <button type="submit" class="btn btn-primary btn-sm mt-1">Add to Basket</button>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm mt-1" disabled>Out of Stock</button>
                            }
                        </form>
                    }
                    else if (!User.Identity.IsAuthenticated)
                    {
                        <br />
                        <a asp-area="Identity" asp-page="/Account/Login"
                           class="btn btn-outline-primary btn-sm mt-1">Login to Buy</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>