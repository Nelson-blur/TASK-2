@model GreenFieldWeb.Models.Products
@{
    ViewData["Title"] = "Delete Product";
}

<div class="glh-confirm-wrap">
    <div class="glh-confirm">
        <div class="glh-confirm-icon">⚠️</div>
        <h1>Delete Product?</h1>
        <p>This will permanently remove <strong>@Model.ProductName</strong>.</p>

        <div class="glh-detail-list">
            <div class="glh-detail-row"><span>Product</span><strong>@Model.ProductName</strong></div>
            <div class="glh-detail-row"><span>Price</span><strong>£@Model.Price.ToString("0.00")</strong></div>
            <div class="glh-detail-row"><span>Stock</span><strong>@Model.Stock units</strong></div>
            <div class="glh-detail-row"><span>Producer</span><strong>@(Model.Producers?.ProducerName ?? "Unknown")</strong></div>
        </div>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductsId" />
                <button type="submit" class="btn btn-danger px-4" aria-label="Confirm delete @Model.ProductName">Yes, Delete</button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </div>
</div>
