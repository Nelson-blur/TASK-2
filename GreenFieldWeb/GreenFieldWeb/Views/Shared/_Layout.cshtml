<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Greenfield Local Hub — Fresh, locally grown food from farmers you can trust." />
    <title>@ViewData["Title"] - Greenfield Local Hub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site_patch.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GreenFieldWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Skip link -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- TTS bar -->
    <div id="tts-bar" style="display:none;background:#1A4A1A;color:white;text-align:center;padding:6px;font-size:12px;font-weight:600;">
        🔊 Text-to-Speech active — click any text to hear it read aloud &nbsp;
        <button onclick="disableTTS()" style="background:rgba(255,255,255,0.2);border:none;color:white;border-radius:6px;padding:2px 10px;font-size:11px;cursor:pointer;">Turn off</button>
    </div>

    <!-- ── SIDEBAR OFFCANVAS ───────────────────────── -->
    <div class="offcanvas offcanvas-start glh-offcanvas" tabindex="-1" id="glhSidebar" aria-labelledby="glhSidebarLabel">
        <div class="offcanvas-header" style="background:var(--green-dark);border-bottom:1px solid rgba(255,255,255,.1);">
            <h5 id="glhSidebarLabel" style="color:#fff;font-weight:800;margin:0;">🌿 GLH Menu</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close menu"></button>
        </div>
        <div class="offcanvas-body" style="background:var(--green-dark);padding:0;">
            <nav aria-label="Sidebar navigation">
                <div class="glh-sb-section">Navigation</div>
                <a class="glh-sb-link" asp-controller="Home" asp-action="Index">🏠 Home</a>
                <a class="glh-sb-link" asp-controller="Products" asp-action="Index">📦 Products</a>
                <a class="glh-sb-link" asp-controller="Producers" asp-action="Index">🧑‍🌾 Producers</a>
                <a class="glh-sb-link" asp-controller="Home" asp-action="ContactUs">✉️ Contact Us</a>
                <a class="glh-sb-link" asp-controller="Home" asp-action="Privacy">🔒 Privacy Policy</a>

                @if (User.Identity.IsAuthenticated && !User.IsInRole("Producer") && !User.IsInRole("Admin"))
                {
                    <div class="glh-sb-section">My Account</div>
                    <a class="glh-sb-link" asp-controller="Baskets" asp-action="Index">🛒 My Basket</a>
                    <a class="glh-sb-link" asp-controller="Orders" asp-action="Index">🧾 My Orders</a>
                }

                @if (User.IsInRole("Producer") || User.IsInRole("Admin"))
                {
                    <div class="glh-sb-section">Producer Tools</div>
                    <a class="glh-sb-link" asp-controller="ProducerDashboard" asp-action="Index">📊 Dashboard</a>
                    <a class="glh-sb-link" asp-controller="Products" asp-action="Index">📋 My Products</a>
                    <a class="glh-sb-link" asp-controller="Orders" asp-action="Index">🧾 Orders</a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <div class="glh-sb-section">Admin</div>
                    <a class="glh-sb-link" asp-controller="Orders" asp-action="Index">📋 All Orders</a>
                    <a class="glh-sb-link" asp-controller="Producers" asp-action="Index">🏭 All Producers</a>
                }

                <div class="glh-sb-section">Accessibility</div>
                <div style="padding:.5rem 1.25rem;">
                    <div style="display:flex;gap:6px;margin-bottom:8px;">
                        <button class="glh-sb-a11y-btn" onclick="setFont('')">A</button>
                        <button class="glh-sb-a11y-btn" onclick="setFont('lg')">A+</button>
                        <button class="glh-sb-a11y-btn" onclick="setFont('xl')">A++</button>
                    </div>
                    <button class="glh-sb-full-btn" onclick="toggleDark()">🌙 Dark Mode</button>
                    <button class="glh-sb-full-btn" onclick="toggleContrast()">◑ High Contrast</button>
                    <button class="glh-sb-full-btn" onclick="toggleTTS()">🔊 Text to Speech</button>
                    <button class="glh-sb-full-btn" onclick="stopSpeech()">⏹ Stop Reading</button>
                </div>
            </nav>
        </div>
    </div>

    <!-- ── NAVBAR ─────────────────────────────────── -->
    <header>
        <nav class="navbar navbar-expand-lg" aria-label="Main navigation">
            <div class="container">

                <!-- Sidebar toggle -->
                <button class="glh-sidebar-toggle me-2"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#glhSidebar"
                        aria-controls="glhSidebar"
                        aria-label="Open navigation menu">
                    ☰
                </button>

                <!-- Brand -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index" aria-label="Greenfield Local Hub home">
                    🌿 Greenfield Local Hub
                    <span class="brand-sub">Farm Fresh · Locally Sourced</span>
                </a>

                <!-- Hamburger (mobile collapse) -->
                <button class="navbar-toggler ms-auto me-2" type="button"
                        data-bs-toggle="collapse" data-bs-target="#glhNav"
                        aria-controls="glhNav" aria-expanded="false"
                        aria-label="Toggle navigation"
                        style="border-color:rgba(255,255,255,.4);">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="glhNav">
                    <!-- Left: core nav only — rest in sidebar -->
                    <ul class="navbar-nav me-auto gap-1" role="menubar">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Products</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Producers" asp-action="Index">Producers</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="ContactUs">Contact</a></li>
                    </ul>

                    <!-- Right: basket + login only -->
                    <ul class="navbar-nav align-items-center gap-2">
                        @if (User.Identity.IsAuthenticated && !User.IsInRole("Producer") && !User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link glh-basket-btn" asp-controller="Baskets" asp-action="Index" aria-label="View basket">🛒 Basket</a>
                            </li>
                        }

                        <!-- Accessibility dropdown — compact -->
                        <li class="nav-item dropdown">
                            <button class="glh-a11y-dropdown-btn"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    aria-label="Accessibility options"
                                    id="a11yDropdown">
                                ♿
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end glh-a11y-menu" aria-labelledby="a11yDropdown">
                                <li class="glh-a11y-section-label">Text Size</li>
                                <li>
                                    <div class="glh-a11y-row">
                                        <button class="glh-a11y-opt" onclick="setFont('')">A<span>Normal</span></button>
                                        <button class="glh-a11y-opt" onclick="setFont('lg')">A+<span>Large</span></button>
                                        <button class="glh-a11y-opt" onclick="setFont('xl')">A++<span>X-Large</span></button>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button class="glh-a11y-full-btn" onclick="toggleDark()">🌙 <span id="darkLabel">Dark Mode</span></button></li>
                                <li><button class="glh-a11y-full-btn" onclick="toggleContrast()">◑ <span id="contrastLabel">High Contrast</span></button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button class="glh-a11y-full-btn" onclick="toggleTTS()" id="ttsBtn">🔊 Text to Speech</button></li>
                                <li><button class="glh-a11y-full-btn" onclick="stopSpeech()">⏹ Stop Reading</button></li>
                            </ul>
                        </li>

                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main -->
    <div class="container" style="padding-top:1.5rem;padding-bottom:2rem;">
        <main id="main-content" role="main" tabindex="-1">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="glh-footer" role="contentinfo">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5>🌿 Greenfield Local Hub</h5>
                    <p>A cooperative of local farmers and food producers bringing you fresh, traceable food from farm to fork.</p>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <h5>Shop</h5>
                    <a asp-controller="Products" asp-action="Index">All Products</a>
                    <a asp-controller="Producers" asp-action="Index">Our Producers</a>
                    @if (User.Identity.IsAuthenticated && !User.IsInRole("Producer") && !User.IsInRole("Admin"))
                    {
                        <a asp-controller="Baskets" asp-action="Index">My Basket</a>
                        <a asp-controller="Orders" asp-action="Index">Order History</a>
                    }
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <h5>Info</h5>
                    <a asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-controller="Home" asp-action="ContactUs">Contact Us</a>
                    <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h5>Get in Touch</h5>
                    <p>📍 Market Lane, Greenfield GF1 2AB</p>
                    <p>📞 <a href="tel:01234567890">01234 567890</a></p>
                    <p>✉️ <a href="mailto:hello@greenfieldlocalhub.co.uk">hello@greenfieldlocalhub.co.uk</a></p>
                    <p>Mon–Sat 09:00–18:00 · Sun 10:00–16:00</p>
                </div>
            </div>
            <div class="glh-footer-bottom">
                © 2026 Greenfield Local Hub ·
                <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a> ·
                Designed to WCAG 2.1 AA
            </div>
        </div>
    </footer>

    <!-- Toast -->
    <div id="glh-toast" aria-live="polite" aria-atomic="true"
         style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;display:none;">
        <div style="background:#1A4A1A;color:white;padding:12px 20px;border-radius:14px;font-size:14px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,.2);display:flex;align-items:center;gap:10px;min-width:220px;">
            <span id="glh-toast-icon">✅</span>
            <span id="glh-toast-msg">Added to basket!</span>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Dark Mode ──────────────────────────────────
        function toggleDark() {
            const html = document.documentElement;
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('glh-theme', next);
            document.querySelectorAll('#darkLabel').forEach(el => el.textContent = next === 'dark' ? 'Light Mode' : 'Dark Mode');
        }

        // ── High Contrast ──────────────────────────────
        function toggleContrast() {
            const html = document.documentElement;
            const next = html.getAttribute('data-contrast') === 'high' ? '' : 'high';
            html.setAttribute('data-contrast', next);
            localStorage.setItem('glh-contrast', next);
            document.querySelectorAll('#contrastLabel').forEach(el => el.textContent = next === 'high' ? 'Normal Contrast' : 'High Contrast');
        }

        // ── Font Size — applies to html element so rem units scale ──
        function setFont(size) {
            const html = document.documentElement;
            html.removeAttribute('data-fontsize');
            if (size === 'lg')  html.setAttribute('data-fontsize', 'lg');
            if (size === 'xl')  html.setAttribute('data-fontsize', 'xl');
            localStorage.setItem('glh-fontsize', size || '');
        }

        // ── TTS ────────────────────────────────────────
        let ttsEnabled = false;
        function toggleTTS() {
            ttsEnabled = !ttsEnabled;
            localStorage.setItem('glh-tts', ttsEnabled);
            document.getElementById('tts-bar').style.display = ttsEnabled ? 'block' : 'none';
            if (!ttsEnabled) window.speechSynthesis.cancel();
        }
        function disableTTS() {
            ttsEnabled = false;
            localStorage.setItem('glh-tts', false);
            document.getElementById('tts-bar').style.display = 'none';
            window.speechSynthesis.cancel();
        }
        function stopSpeech() { window.speechSynthesis.cancel(); }

        document.addEventListener('click', function(e) {
            if (!ttsEnabled) return;
            const tag = e.target.tagName.toLowerCase();
            if (['a','button','input','select','textarea'].includes(tag)) return;
            const text = e.target.innerText || e.target.textContent;
            if (text && text.trim().length > 1) {
                window.speechSynthesis.cancel();
                const utt = new SpeechSynthesisUtterance(text.trim());
                utt.lang = 'en-GB'; utt.rate = 0.95;
                window.speechSynthesis.speak(utt);
            }
        });

        // ── Toast ──────────────────────────────────────
        function showToast(msg, icon = '✅', error = false) {
            const toast = document.getElementById('glh-toast');
            document.getElementById('glh-toast-msg').textContent = msg;
            document.getElementById('glh-toast-icon').textContent = icon;
            toast.querySelector('div').style.background = error ? '#D9534F' : '#1A4A1A';
            toast.style.display = 'block';
            setTimeout(() => { toast.style.display = 'none'; }, 3000);
        }

        // ── AJAX basket ────────────────────────────────
        document.addEventListener('submit', function(e) {
            const form = e.target;
            if (!form.classList.contains('glh-ajax-basket')) return;
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]');
            const orig = btn ? btn.textContent : '';
            if (btn) { btn.textContent = 'Adding…'; btn.disabled = true; }
            fetch(form.action, { method:'POST', body: new FormData(form), headers:{'X-Requested-With':'XMLHttpRequest'} })
            .then(res => {
                if (res.ok || res.redirected) {
                    showToast('Added to basket! 🛒');
                    if (btn) { btn.textContent = '✓ Added'; btn.disabled = false; }
                    setTimeout(() => { if (btn) btn.textContent = orig; }, 2000);
                } else {
                    showToast('Something went wrong', '❌', true);
                    if (btn) { btn.textContent = orig; btn.disabled = false; }
                }
            })
            .catch(() => {
                showToast('Something went wrong', '❌', true);
                if (btn) { btn.textContent = orig; btn.disabled = false; }
            });
        });

        // ── Restore preferences ────────────────────────
        (function () {
            const t  = localStorage.getItem('glh-theme');
            const c  = localStorage.getItem('glh-contrast');
            const f  = localStorage.getItem('glh-fontsize');
            const ts = localStorage.getItem('glh-tts');
            if (t) {
                document.documentElement.setAttribute('data-theme', t);
                document.querySelectorAll('#darkLabel').forEach(el => el.textContent = t === 'dark' ? 'Light Mode' : 'Dark Mode');
            }
            if (c && c === 'high') {
                document.documentElement.setAttribute('data-contrast', 'high');
                document.querySelectorAll('#contrastLabel').forEach(el => el.textContent = 'Normal Contrast');
            }
            if (f === 'lg')  document.documentElement.setAttribute('data-fontsize', 'lg');
            if (f === 'xl')  document.documentElement.setAttribute('data-fontsize', 'xl');
            if (ts === 'true') { ttsEnabled = true; document.getElementById('tts-bar').style.display = 'block'; }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
