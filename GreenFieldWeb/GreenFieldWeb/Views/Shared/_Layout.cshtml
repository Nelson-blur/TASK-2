<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Greenfield Local Hub — Fresh, locally grown food from farmers you can trust." />
    <title>@ViewData["Title"] - Greenfield Local Hub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GreenFieldWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Skip link -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Announcement bar -->
    <div class="glh-announce" role="complementary" aria-label="Announcements">
        🏷 Loyalty points on every purchase &nbsp;·&nbsp;
        <a asp-controller="Home" asp-action="ContactUs">Get in touch</a>
    </div>

    <!-- Text to speech indicator -->
    <div id="tts-bar" style="display:none; background:#1A4A1A; color:white; text-align:center; padding:6px; font-size:12px; font-weight:600;">
        🔊 Text-to-Speech active — click any text to hear it read aloud &nbsp;
        <button onclick="disableTTS()" style="background:rgba(255,255,255,0.2);border:none;color:white;border-radius:6px;padding:2px 10px;font-size:11px;cursor:pointer;">Turn off</button>
    </div>

    <header>
        <nav class="navbar navbar-expand-lg" aria-label="Main navigation">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index" aria-label="Greenfield Local Hub home">
                    🌿 Greenfield Local Hub
                    <span class="brand-sub">Farm Fresh · Locally Sourced</span>
                </a>

                <!-- Hamburger (mobile) -->
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#glhNav"
                        aria-controls="glhNav" aria-expanded="false"
                        aria-label="Toggle navigation menu"
                        style="border-color:rgba(255,255,255,.4);">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="glhNav">

                    <!-- Left links -->
                    <ul class="navbar-nav me-auto gap-1" role="menubar">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" role="menuitem">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index" role="menuitem">Products</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Producers" asp-action="Index" role="menuitem">Producers</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="ContactUs" role="menuitem">Contact</a></li>

                        @if (User.IsInRole("Producer") || User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ProducerDashboard" asp-action="Index" role="menuitem">📊 Dashboard</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Orders" asp-action="Index" role="menuitem">All Orders</a>
                            </li>
                        }
                    </ul>

                    <!-- Right: accessibility dropdown + user links -->
                    <ul class="navbar-nav align-items-center gap-2">

                        <!-- Accessibility Dropdown -->
                        <li class="nav-item dropdown">
                            <button class="glh-a11y-dropdown-btn dropdown-toggle"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    aria-label="Accessibility options"
                                    id="a11yDropdown">
                                ♿ Accessibility
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end glh-a11y-menu" aria-labelledby="a11yDropdown">
                                <li class="glh-a11y-section-label">Text Size</li>
                                <li>
                                    <div class="glh-a11y-row">
                                        <button class="glh-a11y-opt" onclick="setFont('')"  aria-label="Normal text size">A <span>Normal</span></button>
                                        <button class="glh-a11y-opt" onclick="setFont('lg')" aria-label="Large text size">A+ <span>Large</span></button>
                                        <button class="glh-a11y-opt" onclick="setFont('xl')" aria-label="Extra large text">A++ <span>X-Large</span></button>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li class="glh-a11y-section-label">Display</li>
                                <li>
                                    <button class="glh-a11y-full-btn" onclick="toggleDark()" aria-label="Toggle dark mode">
                                        🌙 <span id="darkLabel">Dark Mode</span>
                                    </button>
                                </li>
                                <li>
                                    <button class="glh-a11y-full-btn" onclick="toggleContrast()" aria-label="Toggle high contrast">
                                        ◑ <span id="contrastLabel">High Contrast</span>
                                    </button>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li class="glh-a11y-section-label">Reading</li>
                                <li>
                                    <button class="glh-a11y-full-btn" onclick="toggleTTS()" aria-label="Toggle text to speech" id="ttsBtn">
                                        🔊 <span>Text to Speech</span>
                                    </button>
                                </li>
                                <li>
                                    <button class="glh-a11y-full-btn" onclick="stopSpeech()" aria-label="Stop reading">
                                        ⏹ <span>Stop Reading</span>
                                    </button>
                                </li>
                            </ul>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (!User.IsInRole("Producer") && !User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link glh-basket-btn" asp-controller="Baskets" asp-action="Index" aria-label="View basket">🛒 Basket</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Orders" asp-action="Index">My Orders</a>
                                </li>
                            }
                        }

                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main -->
    <div class="container" style="padding-top:1.5rem; padding-bottom:2rem;">
        <main id="main-content" role="main" tabindex="-1">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="glh-footer" role="contentinfo" aria-label="Site footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5>🌿 Greenfield Local Hub</h5>
                    <p>A cooperative of local farmers and food producers bringing you fresh, traceable food from farm to fork.</p>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <h5>Shop</h5>
                    <a asp-controller="Products" asp-action="Index">All Products</a>
                    <a asp-controller="Producers" asp-action="Index">Our Producers</a>
                    @if (User.Identity.IsAuthenticated && !User.IsInRole("Producer") && !User.IsInRole("Admin"))
                    {
                        <a asp-controller="Baskets" asp-action="Index">My Basket</a>
                        <a asp-controller="Orders" asp-action="Index">Order History</a>
                    }
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <h5>Info</h5>
                    <a asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-controller="Home" asp-action="ContactUs">Contact Us</a>
                    <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h5>Get in Touch</h5>
                    <p>📍 Market Lane, Greenfield GF1 2AB</p>
                    <p>📞 <a href="tel:01234567890">01234 567890</a></p>
                    <p>✉️ <a href="mailto:hello@greenfieldlocalhub.co.uk">hello@greenfieldlocalhub.co.uk</a></p>
                    <p>Mon–Sat 09:00–18:00 · Sun 10:00–16:00</p>
                </div>
            </div>
            <div class="glh-footer-bottom">
                © 2026 Greenfield Local Hub ·
                <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a> ·
                Designed to WCAG 2.1 AA
            </div>
        </div>
    </footer>

    <!-- Toast notification for basket -->
    <div id="glh-toast" aria-live="polite" aria-atomic="true"
         style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;display:none;">
        <div style="background:#1A4A1A;color:white;padding:12px 20px;border-radius:14px;font-size:14px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:10px;min-width:220px;">
            <span id="glh-toast-icon">✅</span>
            <span id="glh-toast-msg">Added to basket!</span>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Dark Mode ─────────────────────────────────
        function toggleDark() {
            const html = document.documentElement;
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('glh-theme', next);
            document.getElementById('darkLabel').textContent = next === 'dark' ? 'Light Mode' : 'Dark Mode';
        }

        // ── High Contrast ──────────────────────────────
        function toggleContrast() {
            const html = document.documentElement;
            const next = html.getAttribute('data-contrast') === 'high' ? '' : 'high';
            html.setAttribute('data-contrast', next);
            localStorage.setItem('glh-contrast', next);
            document.getElementById('contrastLabel').textContent = next === 'high' ? 'Normal Contrast' : 'High Contrast';
        }

        // ── Font Size ──────────────────────────────────
        function setFont(size) {
            document.body.setAttribute('data-fontsize', size);
            localStorage.setItem('glh-fontsize', size);
        }

        // ── Text to Speech ─────────────────────────────
        let ttsEnabled = false;

        function toggleTTS() {
            ttsEnabled = !ttsEnabled;
            localStorage.setItem('glh-tts', ttsEnabled);
            document.getElementById('tts-bar').style.display = ttsEnabled ? 'block' : 'none';
            document.getElementById('ttsBtn').style.background = ttsEnabled ? 'rgba(107,191,89,0.2)' : '';
            if (!ttsEnabled) window.speechSynthesis.cancel();
        }

        function disableTTS() {
            ttsEnabled = false;
            localStorage.setItem('glh-tts', false);
            document.getElementById('tts-bar').style.display = 'none';
            document.getElementById('ttsBtn').style.background = '';
            window.speechSynthesis.cancel();
        }

        function stopSpeech() {
            window.speechSynthesis.cancel();
        }

        // Click to read
        document.addEventListener('click', function(e) {
            if (!ttsEnabled) return;
            // Don't read button/link clicks that navigate
            const tag = e.target.tagName.toLowerCase();
            if (tag === 'a' || tag === 'button' || tag === 'input' || tag === 'select') return;

            const text = e.target.innerText || e.target.textContent;
            if (text && text.trim().length > 0) {
                window.speechSynthesis.cancel();
                const utt = new SpeechSynthesisUtterance(text.trim());
                utt.lang = 'en-GB';
                utt.rate = 0.95;
                window.speechSynthesis.speak(utt);
            }
        });

        // ── Toast Helper ───────────────────────────────
        function showToast(msg, icon = '✅', error = false) {
            const toast = document.getElementById('glh-toast');
            document.getElementById('glh-toast-msg').textContent = msg;
            document.getElementById('glh-toast-icon').textContent = icon;
            toast.querySelector('div').style.background = error ? '#D9534F' : '#1A4A1A';
            toast.style.display = 'block';
            setTimeout(() => { toast.style.display = 'none'; }, 3000);
        }

        // ── AJAX Add to Basket ─────────────────────────
        document.addEventListener('submit', function(e) {
            const form = e.target;
            if (!form.classList.contains('glh-ajax-basket')) return;
            e.preventDefault();

            const btn = form.querySelector('button[type="submit"]');
            const originalText = btn ? btn.textContent : '';
            if (btn) { btn.textContent = 'Adding…'; btn.disabled = true; }

            const data = new FormData(form);

            fetch(form.action, {
                method: 'POST',
                body: data,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(res => {
                if (res.ok || res.redirected) {
                    showToast('Added to basket! 🛒');
                    if (btn) { btn.textContent = '✓ Added'; btn.disabled = false; }
                    setTimeout(() => { if (btn) btn.textContent = originalText; }, 2000);
                } else {
                    showToast('Something went wrong', '❌', true);
                    if (btn) { btn.textContent = originalText; btn.disabled = false; }
                }
            })
            .catch(() => {
                showToast('Something went wrong', '❌', true);
                if (btn) { btn.textContent = originalText; btn.disabled = false; }
            });
        });

        // ── Restore saved preferences ──────────────────
        (function () {
            const t  = localStorage.getItem('glh-theme');
            const c  = localStorage.getItem('glh-contrast');
            const f  = localStorage.getItem('glh-fontsize');
            const ts = localStorage.getItem('glh-tts');

            if (t) {
                document.documentElement.setAttribute('data-theme', t);
                const lbl = document.getElementById('darkLabel');
                if (lbl) lbl.textContent = t === 'dark' ? 'Light Mode' : 'Dark Mode';
            }
            if (c) {
                document.documentElement.setAttribute('data-contrast', c);
                const lbl = document.getElementById('contrastLabel');
                if (lbl && c === 'high') lbl.textContent = 'Normal Contrast';
            }
            if (f) document.body.setAttribute('data-fontsize', f);
            if (ts === 'true') {
                ttsEnabled = true;
                document.getElementById('tts-bar').style.display = 'block';
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
