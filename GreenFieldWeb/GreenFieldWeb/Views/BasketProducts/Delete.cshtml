@model GreenFieldWeb.Models.BasketProducts
@{
    ViewData["Title"] = "Remove Item";
}

<div class="glh-confirm-wrap">
    <div class="glh-confirm">
        <div class="glh-confirm-icon">🗑️</div>
        <h1>Remove Item?</h1>
        <p>Are you sure you want to remove this item from your basket?</p>

        <div class="glh-detail-list">
            <div class="glh-detail-row"><span>Product</span><strong>@(Model.Products?.ProductName ?? "Unknown")</strong></div>
            <div class="glh-detail-row"><span>Quantity</span><strong>@Model.Quantity</strong></div>
        </div>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="BasketProductsId" />
                <button type="submit" class="btn btn-danger px-4" aria-label="Confirm remove item">Yes, Remove</button>
            </form>
            <a asp-controller="Baskets" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </div>
</div>
