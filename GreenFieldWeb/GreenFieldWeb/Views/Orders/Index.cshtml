@model IEnumerable<GreenFieldWeb.Models.Orders>
@{
    ViewData["Title"] = "Orders";
    string heading = User.IsInRole("Admin") ? "All Orders" : User.IsInRole("Producer") ? "Orders Containing Your Products" : "My Orders";
}

<div class="glh-page-header">
    <div><h1>@heading</h1></div>
</div>

@if (!Model.Any())
{
    <div class="glh-empty">
        <div class="glh-empty-icon">📦</div>
        <h3>No orders found</h3>
        <p>Orders will appear here once placed.</p>
        @if (!User.IsInRole("Producer") && !User.IsInRole("Admin"))
        {
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-3 px-4">Shop Now</a>
        }
    </div>
}
else
{
    <div style="background:var(--bg-card);border-radius:var(--radius-md);border:1px solid var(--border);overflow:hidden;box-shadow:var(--shadow);">
        <table class="table mb-0" aria-label="@heading">
            <thead>
                <tr>
                    <th>Order</th>
                    @if (User.IsInRole("Admin")) { <th>Customer</th> }
                    <th>Date</th>
                    <th>Status</th>
                    <th>Method</th>
                    <th>Due</th>
                    <th>Address</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span style="background:#EAF3DE;color:#1A4A1A;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">#@item.OrdersId</span></td>
                        @if (User.IsInRole("Admin")) { <td style="font-size:11.5px;color:var(--text-muted);">@item.UserId.Substring(0, Math.Min(8, item.UserId.Length))…</td> }
                        <td style="font-size:13px;">@item.OrderDate</td>
                        <td>
                            @if (item.OrderStatus == "Pending")           { <span class="status-pending">@item.OrderStatus</span> }
                            else if (item.OrderStatus == "Delivered" || item.OrderStatus == "Collected") { <span class="status-delivered">@item.OrderStatus</span> }
                            else if (item.OrderStatus == "Cancelled")     { <span class="status-cancelled">@item.OrderStatus</span> }
                            else                                           { <span class="status-shipped">@item.OrderStatus</span> }
                        </td>
                        <td style="font-size:13px;">@item.DeliveryMethod</td>
                        <td style="font-size:13px;">@item.DeliveryDate</td>
                        <td style="font-size:12.5px;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @(item.DeliveryMethod == "Collection" ? "N/A" : item.DeliveryAddress)
                        </td>
                        <td style="font-weight:700;font-size:13.5px;">£@item.TotalAmount.ToString("0.00")</td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-action="Details" asp-route-id="@item.OrdersId"
                                   class="btn btn-sm btn-outline-secondary"
                                   aria-label="View details for order #@item.OrdersId">Details</a>
                                @if (User.IsInRole("Producer") || User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.OrdersId"
                                       class="btn btn-sm btn-primary"
                                       aria-label="Update status for order #@item.OrdersId">Update</a>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.OrdersId"
                                       class="btn btn-sm btn-danger"
                                       aria-label="Delete order #@item.OrdersId">Delete</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
