@model GreenFieldWeb.Models.Orders
@{
    ViewData["Title"] = "Update Order Status";
}

<div class="glh-form-wrap">
    <div class="glh-form-card" style="max-width:480px;">
        <h1 class="glh-form-title">Update Order Status</h1>
        <p class="glh-form-sub">Order #@Model.OrdersId · placed @Model.OrderDate</p>

        <!-- Order summary -->
        <div class="glh-detail-list mb-3">
            <div class="glh-detail-row"><span>Method</span><strong>@Model.DeliveryMethod</strong></div>
            <div class="glh-detail-row"><span>Total</span><strong>£@Model.TotalAmount.ToString("0.00")</strong></div>
            <div class="glh-detail-row">
                <span>Current Status</span>
                <strong>
                    @if (Model.OrderStatus == "Pending")          { <span class="status-pending">@Model.OrderStatus</span> }
                    else if (Model.OrderStatus == "Delivered" || Model.OrderStatus == "Collected") { <span class="status-delivered">@Model.OrderStatus</span> }
                    else                                           { <span class="status-shipped">@Model.OrderStatus</span> }
                </strong>
            </div>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.OrdersId" />

            <div class="glh-field">
                <label for="OrderStatus" class="glh-label">New Status</label>
                <select name="OrderStatus" id="OrderStatus" class="form-select" aria-label="Select new order status">
                    <option value="">-- Select Status --</option>
                    <option value="Pending"              selected="@(Model.OrderStatus=="Pending")">Pending</option>
                    <option value="Processing"           selected="@(Model.OrderStatus=="Processing")">Processing</option>
                    <option value="Shipped"              selected="@(Model.OrderStatus=="Shipped")">Shipped</option>
                    <option value="Out for Delivery"     selected="@(Model.OrderStatus=="Out for Delivery")">Out for Delivery</option>
                    <option value="Delivered"            selected="@(Model.OrderStatus=="Delivered")">Delivered</option>
                    <option value="Ready for Collection" selected="@(Model.OrderStatus=="Ready for Collection")">Ready for Collection</option>
                    <option value="Collected"            selected="@(Model.OrderStatus=="Collected")">Collected</option>
                    <option value="Cancelled"            selected="@(Model.OrderStatus=="Cancelled")">Cancelled</option>
                </select>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary px-4" aria-label="Save new status">Save Status</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
