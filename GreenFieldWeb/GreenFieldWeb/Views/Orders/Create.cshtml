@model GreenFieldWeb.Models.Orders

@{
    ViewData["Title"] = "Checkout";
}

<h1>Checkout</h1>
<p>Choose how you would like to receive your order.</p>


<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" style="color:red;"></div>

    <input type="hidden" name="basketId" value="@ViewBag.BasketId" />

    <!-- Order Method -->
    <div style="margin-bottom: 20px;">
        <label style="font-weight:bold; display:block; margin-bottom:10px;">Order Method</label>

        <div>
            <input asp-for="DeliveryMethod" type="radio" id="deliveryCheck" value="Delivery" />
            <label for="deliveryCheck">Delivery</label>
        </div>

        <div>
            <input asp-for="DeliveryMethod" type="radio" id="collectionCheck" value="Collection" />
            <label for="collectionCheck">Collection</label>
        </div>
    </div>

    <!-- Delivery Date (used for BOTH delivery + collection) -->
    <div id="dateGroup" style="display:none; margin-bottom:15px;">
        <label asp-for="DeliveryDate" id="dateLabel">Date</label>
        <input asp-for="DeliveryDate" type="date" />
        <span asp-validation-for="DeliveryDate" style="color:red;"></span>
        <div id="dateHint"></div>
    </div>

    <!-- Delivery Address (only for delivery) -->
    <div id="addressGroup" style="display:none; margin-bottom:15px;">
        <label asp-for="DeliveryAddress"></label>
        <input asp-for="DeliveryAddress" type="text" />
        <span asp-validation-for="DeliveryAddress" style="color:red;"></span>
    </div>

    <button type="submit">Place Order</button>

    <div style="margin-top:10px;">
        <a asp-controller="Baskets" asp-action="Index">Back to Basket</a>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const deliveryRadio = document.getElementById('deliveryCheck');
            const collectionRadio = document.getElementById('collectionCheck');

            const dateGroup = document.getElementById('dateGroup');
            const addressGroup = document.getElementById('addressGroup');

            const dateLabel = document.getElementById('dateLabel');
            const dateHint = document.getElementById('dateHint');

            const dateInput = document.querySelector("input[name='DeliveryDate']");

            // ✅ enforce "2 days from today" rule
            if (dateInput) {
                const today = new Date();
                today.setDate(today.getDate() + 2);
                dateInput.min = today.toISOString().split("T")[0];
            }

            function toggleSections() {

                if (deliveryRadio.checked) {

                    // show both for delivery
                    dateGroup.style.display = 'block';
                    addressGroup.style.display = 'block';

                    dateLabel.innerText = "Delivery Date";
                    dateHint.innerText = "";
                }

                else if (collectionRadio.checked) {

                    // show date only for collection
                    dateGroup.style.display = 'block';
                    addressGroup.style.display = 'none';

                    dateLabel.innerText = "Collection Date";
                    dateHint.innerText = "Earliest collection date is 2 days from today.";
                }

                else {

                    // nothing selected yet
                    dateGroup.style.display = 'none';
                    addressGroup.style.display = 'none';
                }
            }

            deliveryRadio.addEventListener('change', toggleSections);
            collectionRadio.addEventListener('change', toggleSections);

            toggleSections();
        });
    </script>
}