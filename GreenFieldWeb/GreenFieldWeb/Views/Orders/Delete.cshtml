@model GreenFieldWeb.Models.Orders
@{
    ViewData["Title"] = "Delete Order";
}

<div class="glh-confirm-wrap">
    <div class="glh-confirm">
        <div class="glh-confirm-icon">⚠️</div>
        <h1>Delete Order?</h1>
        <p>This will permanently delete Order <strong>#@Model.OrdersId</strong>.</p>

        <div class="glh-detail-list">
            <div class="glh-detail-row"><span>Date</span><strong>@Model.OrderDate</strong></div>
            <div class="glh-detail-row"><span>Status</span><strong>@Model.OrderStatus</strong></div>
            <div class="glh-detail-row"><span>Method</span><strong>@Model.DeliveryMethod</strong></div>
            <div class="glh-detail-row"><span>Total</span><strong>£@Model.TotalAmount.ToString("0.00")</strong></div>
        </div>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="OrdersId" />
                <button type="submit" class="btn btn-danger px-4" aria-label="Confirm delete order #@Model.OrdersId">Yes, Delete</button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </div>
</div>
