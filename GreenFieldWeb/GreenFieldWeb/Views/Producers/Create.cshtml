@model GreenFieldWeb.Models.Producers
@{
    ViewData["Title"] = "Add Producer";
}

<div class="glh-form-wrap">
    <div class="glh-form-card">
        <h1 class="glh-form-title">Add New Producer</h1>
        <p class="glh-form-sub">Register a new local farmer or food producer.</p>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="glh-error-box"></div>

            <div class="glh-field">
                <label asp-for="ProducerName" class="glh-label"></label>
                <input asp-for="ProducerName" class="form-control" placeholder="e.g. Green Acres Farm" />
                <span asp-validation-for="ProducerName" class="glh-error"></span>
            </div>
            <div class="glh-field">
                <label asp-for="Description" class="glh-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Tell customers about this producer..."></textarea>
                <span asp-validation-for="Description" class="glh-error"></span>
            </div>
            <div class="glh-field">
                <label asp-for="BusinessLocation" class="glh-label"></label>
                <input asp-for="BusinessLocation" class="form-control" placeholder="e.g. Worcestershire" />
                <span asp-validation-for="BusinessLocation" class="glh-error"></span>
            </div>
            <div class="glh-field">
                <label asp-for="ContactEmail" class="glh-label"></label>
                <input asp-for="ContactEmail" type="email" class="form-control" placeholder="producer@example.com" />
                <span asp-validation-for="ContactEmail" class="glh-error"></span>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary px-4">Create Producer</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
