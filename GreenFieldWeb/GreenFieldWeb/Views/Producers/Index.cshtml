@model IEnumerable<GreenFieldWeb.Models.Producers>
@{
    ViewData["Title"] = "Our Producers";
}

<div style="background:linear-gradient(135deg,#1A4A1A,#2F6F4E);border-radius:20px;padding:2.25rem 2rem;margin-bottom:2rem;text-align:center;">
    <p style="font-size:11px;font-weight:800;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:1.5px;margin:0 0 5px;">Supporting local farms and artisans</p>
    <h1 style="color:#fff;font-weight:900;font-size:1.9rem;margin:0 0 6px;">Meet our producers</h1>
    <p style="color:rgba(255,255,255,.78);font-size:.9rem;margin:0;">The local farmers and artisans who make GLH possible</p>
</div>

<div class="glh-page-header">
    <p style="color:var(--text-muted);font-size:.875rem;margin:0;">@Model.Count() producers listed</p>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success" aria-label="Add new producer">+ Add Producer</a>
    }
</div>

@if (!Model.Any())
{
    <div class="glh-empty">
        <div class="glh-empty-icon">🌱</div>
        <h3>No producers yet</h3>
        <p>Check back soon.</p>
    </div>
}
else
{
    <div class="row g-4" role="list" aria-label="Producers">
        @foreach (var item in Model)
        {
            <div class="col-md-3 col-sm-6" role="listitem">
                <article class="glh-card h-100 d-flex flex-column" style="padding:1.4rem;">
                    <div style="width:52px;height:52px;background:#EAF3DE;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin-bottom:.9rem;" aria-hidden="true">🧑‍🌾</div>
                    <div style="flex:1;">
                        <h3 style="font-size:14.5px;font-weight:800;color:var(--green-dark);margin:0 0 3px;">@item.ProducerName</h3>
                        <p style="font-size:11.5px;color:var(--green-mid);font-weight:700;margin:0 0 7px;">📍 @item.BusinessLocation</p>
                        <p style="font-size:12.5px;color:var(--text-muted);line-height:1.6;margin:0 0 7px;">
                            @(item.Description?.Length > 85 ? item.Description.Substring(0, 85) + "…" : item.Description)
                        </p>
                        <p style="font-size:12px;color:var(--text-muted);margin:0;">✉️ @item.ContactEmail</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap mt-3">
                        <a asp-action="Details" asp-route-id="@item.ProducersId"
                           class="btn btn-sm"
                           style="background:transparent;border:2px solid var(--green-mid);color:var(--green-mid);border-radius:20px;font-weight:700;font-size:11.5px;"
                           aria-label="View details for @item.ProducerName">View Details</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.ProducersId"
                               class="btn btn-sm"
                               style="background:transparent;border:1px solid var(--border);color:var(--text-muted);border-radius:20px;font-size:11.5px;"
                               aria-label="Edit @item.ProducerName">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.ProducersId"
                               class="btn btn-sm"
                               style="background:transparent;border:1px solid #D9534F;color:#D9534F;border-radius:20px;font-size:11.5px;"
                               aria-label="Delete @item.ProducerName">Delete</a>
                        }
                    </div>
                </article>
            </div>
        }
    </div>
}
