@model GreenFieldWeb.Models.Producers
@{
    ViewData["Title"] = "Delete Producer";
}

<div class="glh-confirm-wrap">
    <div class="glh-confirm">
        <div class="glh-confirm-icon">⚠️</div>
        <h1>Delete Producer?</h1>
        <p>This will permanently remove <strong>@Model.ProducerName</strong>.</p>

        <div class="glh-detail-list">
            <div class="glh-detail-row"><span>Name</span><strong>@Model.ProducerName</strong></div>
            <div class="glh-detail-row"><span>Location</span><strong>@Model.BusinessLocation</strong></div>
            <div class="glh-detail-row"><span>Email</span><strong>@Model.ContactEmail</strong></div>
        </div>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProducersId" />
                <button type="submit" class="btn btn-danger px-4" aria-label="Confirm delete @Model.ProducerName">Yes, Delete</button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </div>
</div>
