@model IEnumerable<GreenFieldWeb.Models.Products>
@{
    ViewData["Title"] = "Producer Dashboard";
}

<h1>Producer Dashboard</h1>

<p><strong>Total Products:</strong> @ViewBag.TotalProducts</p>
<p><strong>Low Stock Products:</strong> @ViewBag.LowStockCount</p>
<p><strong>Total Stock Units:</strong> @ViewBag.TotalStock</p>

@if (!Model.Any())
{
    <p>You do not have any products yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Stock</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Take(5))
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>£@item.Price.ToString("0.00")</td>
                    <td>@item.Stock</td>
                    <td>
                        <a asp-controller="Products" asp-action="Edit"
                           asp-route-id="@item.ProductsId">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
<p>
    <a asp-controller="Products" asp-action="Index">View All Your Products</a>
</p>

<h2>Recent Orders</h2>

@if (ViewBag.RecentOrders == null || ((List<GreenFieldWeb.Models.Orders>)ViewBag.RecentOrders).Count == 0)
{
    <p>No recent orders found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Order Date</th>
                <th>Status</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in ((List<GreenFieldWeb.Models.Orders>)ViewBag.RecentOrders).Take(5))
            {
                <tr>
                    <td>@order.OrdersId</td>
                    <td>@order.OrderDate</td>
                    <td>@order.OrderStatus</td>
                    <td>£@order.TotalAmount.ToString("0.00")</td>
                    <td>
                        <a asp-controller="Orders" asp-action="Details"
                           asp-route-id="@order.OrdersId">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
<p>
	
    <a asp-controller="Orders" asp-action="Index">View All Your Orders</a>
</p>